Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Software\Classes\miku]
@="URL:Miku Protocol"
"URL Protocol"=""

[HKEY_CURRENT_USER\Software\Classes\miku\DefaultIcon]
