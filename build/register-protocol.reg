[HKEY_CURRENT_USER\Software\Classes\miku\shell]

[HKEY_CURRENT_USER\Software\Classes\miku\shell\open]

[HKEY_CURRENT_USER\Software\Classes\miku\shell\open\command]
@="\"G:\\fastbeam\\multiplefolder\\space\\Miku\\bin\\miku.exe\" \"%1\""
